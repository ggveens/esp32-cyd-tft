// ===== START UI DARK MODE =====

// 🎨 Palette dịu mắt
#define BG_COLOR       0x0841   // xám rất đậm (gần đen nhưng dịu)
#define CARD_COLOR     0x1082
#define BORDER_COLOR   0x2104
#define TEXT_PRIMARY   0xFFFF
#define TEXT_SECONDARY 0x7BEF
#define ACCENT_COLOR   0x2D7F   // xanh dịu hơn
#define TIME_COLOR     0xFD20   // vàng nhẹ

// ===== HEADER =====
void drawHeader() {

  tft.fillRect(0, 0, 320, 40, BG_COLOR);
  tft.drawFastHLine(0, 39, 320, BORDER_COLOR);

  tft.setTextSize(1);

  // ===== DÒNG 1: ID (TRÁI) =====
  tft.setTextColor(ACCENT_COLOR, BG_COLOR);
  tft.setCursor(5, 5);
  tft.print("ID:");

  tft.setTextColor(TEXT_PRIMARY, BG_COLOR);
  tft.print(deviceId.substring(0, 10));

  // ===== DÒNG 1: AP (PHẢI) =====
  String apStr = "AP:" + WiFi.softAPIP().toString();
  int16_t apX = 320 - tft.textWidth(apStr) - 5;

  tft.setCursor(apX, 5);
  tft.setTextColor(TEXT_SECONDARY, BG_COLOR);
  tft.print("AP:");

  tft.setTextColor(TEXT_PRIMARY, BG_COLOR);
  tft.print(WiFi.softAPIP());

  // ===== DÒNG 2: WIFI NAME (TRÁI) =====
  String wifiName = WiFi.status() == WL_CONNECTED ? WiFi.SSID() : "No WiFi";

  // nếu tên dài thì cắt
  if (wifiName.length() > 16) {
    wifiName = wifiName.substring(0, 16);
  }

  tft.setCursor(5, 22);
  tft.setTextColor(ACCENT_COLOR, BG_COLOR);
  tft.print(wifiName);

  // ===== DÒNG 2: IP (PHẢI) =====
  String ipStr = "IP:" + WiFi.localIP().toString();
  int16_t ipX = 320 - tft.textWidth(ipStr) - 5;

  tft.setCursor(ipX, 22);
  tft.setTextColor(TEXT_SECONDARY, BG_COLOR);
  tft.print("IP:");

  tft.setTextColor(TEXT_PRIMARY, BG_COLOR);
  tft.print(WiFi.localIP());
}

// ===== TIME =====
void drawTime() {

  static int lastSec = -1;

  struct tm timeinfo;
  if (!getLocalTime(&timeinfo)) return;

  // 👉 chỉ update khi giây thay đổi
  if (timeinfo.tm_sec == lastSec) return;
  lastSec = timeinfo.tm_sec;

  char timeStr[9];
  char dateStr[12];

  strftime(timeStr, sizeof(timeStr), "%H:%M:%S", &timeinfo);
  strftime(dateStr, sizeof(dateStr), "%d/%m/%Y", &timeinfo);

  // ===== TIME =====
  tft.setTextSize(3);

  int16_t timeX = (320 - tft.textWidth(timeStr)) / 2;

  // 👉 overwrite text (KHÔNG clear)
  tft.setTextColor(TIME_COLOR, BG_COLOR);
  tft.setCursor(timeX, 55);
  tft.print(timeStr);

  // ===== DATE (chỉ vẽ 1 lần / khi đổi ngày) =====
  static int lastDay = -1;

  if (timeinfo.tm_mday != lastDay) {
    lastDay = timeinfo.tm_mday;

    tft.setTextSize(1);

    int16_t dateX = (320 - tft.textWidth(dateStr)) / 2;

    // clear nhỏ gọn thôi (không clear cả vùng lớn)
    tft.fillRect(0, 80, 320, 20, BG_COLOR);

    tft.setTextColor(TEXT_SECONDARY, BG_COLOR);
    tft.setCursor(dateX, 85);
    tft.print(dateStr);
  }
}

// ===== RELAY CARD =====
void drawRelayCompact(int y, const char* name, const char* pin, bool state) {

  int x = 10;
  int w = 300;
  int h = 38;

  uint16_t border = state ? 0x07E0 : 0xF800; // xanh / đỏ dịu

  // nền card
  tft.fillRoundRect(x, y, w, h, 6, CARD_COLOR);
  tft.drawRoundRect(x, y, w, h, 6, border);

  // LED
  tft.fillCircle(x + 15, y + h/2, 5, border);

  // Name
  tft.setTextColor(TEXT_PRIMARY, CARD_COLOR);
  tft.setTextSize(1);
  tft.setCursor(x + 28, y + 10);
  tft.print(name);

  // GPIO
  tft.setTextColor(TEXT_SECONDARY, CARD_COLOR);
  tft.setCursor(x + 28, y + 24);
  tft.print(pin);

  // trạng thái
// ===== STATUS BUTTON STYLE =====
uint16_t btnColor  = state ? 0x07E0 : 0xF800;   // nền
uint16_t textColor = state ? TFT_BLACK : TFT_WHITE; // chữ

// vẽ nền
tft.fillRoundRect(x + w - 50, y + 8, 40, 22, 4, btnColor);

// ⚠️ KHÔNG set background nữa → để transparent
tft.setTextColor(textColor);

// canh giữa chữ đẹp hơn
String label = state ? "ON" : "OFF";
int16_t tx = x + w - 50 + (40 - tft.textWidth(label)) / 2;
int16_t ty = y + 8 + (22 / 2) - 4;

tft.setCursor(tx, ty);
tft.print(label);

}

// ===== RELAYS =====
void drawRelays() {
  drawRelayCompact(100, "DISPLAY33", "GPIO27", state1);
  drawRelayCompact(145, "RELAY 2", "GPIO22", state2);
  drawRelayCompact(190, "RELAY 3", "GPIO21", state3);
}

// ===== FOOTER =====
void drawFooter() {

  tft.fillRect(0, 240, 320, 40, BG_COLOR);
  tft.drawFastHLine(0, 240, 320, BORDER_COLOR);

  // MQTT
  tft.setTextColor(TEXT_SECONDARY, BG_COLOR);
  tft.setCursor(10, 250);
  tft.print("MQTT:");

  tft.setTextColor(client.connected() ? 0x07E0 : 0xF800, BG_COLOR);
  tft.print(client.connected() ? " ON" : " OFF");

  // RSSI
  tft.setCursor(150, 250);
  tft.setTextColor(TEXT_SECONDARY, BG_COLOR);
  tft.print("RSSI:");

  tft.setTextColor(TEXT_PRIMARY, BG_COLOR);
  tft.print(WiFi.RSSI());

  // uptime
  tft.setCursor(10, 265);
  tft.setTextColor(TEXT_SECONDARY, BG_COLOR);
  tft.print("UP:");

  unsigned long up = millis()/1000;
  tft.setTextColor(TEXT_PRIMARY, BG_COLOR);
  tft.print(up/3600);
  tft.print("h");
}

// ===== MAIN UI =====
void drawUI() {
  tft.fillScreen(BG_COLOR);
  drawHeader();
  drawTime();
  drawRelays();
  drawFooter();
}

// ===== END UI DARK MODE =====

// ================= RELAY =================

void relay1_on(){ state1=true; digitalWrite(RELAY1,HIGH); drawRelays(); server.send(200,"text/plain","OK"); }
void relay1_off(){ state1=false; digitalWrite(RELAY1,LOW); drawRelays(); server.send(200,"text/plain","OK"); }
void relay2_on(){ state2=true; digitalWrite(RELAY2,LOW); drawRelays(); server.send(200,"text/plain","OK"); }
void relay2_off(){ state2=false; digitalWrite(RELAY2,HIGH); drawRelays(); server.send(200,"text/plain","OK"); }
void relay3_on(){ state3=true; digitalWrite(RELAY3,LOW); drawRelays(); server.send(200,"text/plain","OK"); }
void relay3_off(){ state3=false; digitalWrite(RELAY3,HIGH); drawRelays(); server.send(200,"text/plain","OK"); }

// ================= TIMER RESET DAILY =================
void resetScheduleDaily() {
  static int lastDay = -1;

  struct tm timeinfo;
  if (!getLocalTime(&timeinfo)) return;

  if (timeinfo.tm_mday != lastDay) {
    lastDay = timeinfo.tm_mday;

    for (int i = 0; i < MAX_SCHEDULE; i++) {
      schedules[i].firedOn = false;
      schedules[i].firedOff = false;
    }
  }
}

// ================= TIMER ENGINE =================
void handleSchedule() {

  struct tm timeinfo;
  if (!getLocalTime(&timeinfo)) return;

  int h = timeinfo.tm_hour;
  int m = timeinfo.tm_min;

  for (int i = 0; i < MAX_SCHEDULE; i++) {

    if (!schedules[i].active) continue;

    // ON
    if (!schedules[i].firedOn &&
        h == schedules[i].onH &&
        m == schedules[i].onM) {

      schedules[i].firedOn = true;

      if (schedules[i].relay == 1) relay1_on();
      if (schedules[i].relay == 2) relay2_on();
      if (schedules[i].relay == 3) relay3_on();
    }

    // OFF
    if (!schedules[i].firedOff &&
        h == schedules[i].offH &&
        m == schedules[i].offM) {

      schedules[i].firedOff = true;

      if (schedules[i].relay == 1) relay1_off();
      if (schedules[i].relay == 2) relay2_off();
      if (schedules[i].relay == 3) relay3_off();
    }
  }
}

// ================= MQTT =================
void sendStatusMQTT(){
  String json = "{";
  json += "\"relay1\":" + String(state1?"true":"false") + ",";
  json += "\"relay2\":" + String(state2?"true":"false") + ",";
  json += "\"relay3\":" + String(state3?"true":"false");
  json += "}";

  client.publish(("home/"+deviceId+"/status").c_str(), json.c_str(), true);
}

void callback(char* topic, byte* payload, unsigned int length){
  String msg;
  for(int i=0;i<length;i++) msg+=(char)payload[i];

  if(msg=="relay1_on") relay1_on();
  if(msg=="relay1_off") relay1_off();
  if(msg=="relay2_on") relay2_on();
  if(msg=="relay2_off") relay2_off();
  if(msg=="relay3_on") relay3_on();
  if(msg=="relay3_off") relay3_off();
}

void reconnectMQTT(){
  while(!client.connected()){
    if(client.connect(deviceId.c_str())){
      client.subscribe(("home/"+deviceId+"/relay").c_str());
    } else delay(2000);
  }
}

// ================= SERVER =================

// ===== SCAN WIFI =====
void handleScanWiFi() {

  int n = WiFi.scanNetworks();
  String json = "[";

  for (int i = 0; i < n; i++) {
    if (i) json += ",";
    json += "{";
    json += "\"ssid\":\"" + WiFi.SSID(i) + "\",";
    json += "\"rssi\":" + String(WiFi.RSSI(i));
    json += "}";
  }

  json += "]";

  server.send(200, "application/json", json);
}

// ===== LIST WIFI SAVED =====
void handleListSavedWiFi() {

  String json = "[";

  for (int i = 0; i < MAX_WIFI; i++) {
    if (ssids[i] == "") continue;

    if (json != "[") json += ",";
    json += "{";
    json += "\"ssid\":\"" + ssids[i] + "\"";
    json += "}";
  }

  json += "]";

  server.send(200, "application/json", json);
}

// ===== SET WIFI (FIX LỖI NẰM Ở ĐÂY) =====
void handleSetWiFi() {

  if (!server.hasArg("ssid") || !server.hasArg("pass")) {
    server.send(400, "application/json", "{\"error\":\"missing ssid/pass\"}");
    return;
  }

  String newSSID = server.arg("ssid");
  String newPASS = server.arg("pass");

  Serial.println("SET WIFI:");
  Serial.println(newSSID);

  // lưu vào flash
  saveWiFi(newSSID, newPASS);

  server.send(200, "application/json", "{\"status\":\"saved, restarting\"}");

  delay(1000);
  ESP.restart();
}

// ===== RESET DEVICE =====
void handleResetDevice() {
  server.send(200, "text/plain", "Restarting...");
  delay(1000);
  ESP.restart();
}

