<script>
function add(){
  let r = document.getElementById("relay").value;
  let on = document.getElementById("on").value;
  let off = document.getElementById("off").value;

  fetch(`/api/schedule/add?relay=${r}&on=${on}&off=${off}`)
  .then(r=>r.text())
  .then(()=>load());
}

function load(){
  fetch('/api/schedule/list')
  .then(r=>r.json())
  .then(d=>{
    let h="";
    d.forEach((s,i)=>{
      h+=`<div>
      R${s.relay} ${s.on}→${s.off}
      <button onclick="del(${i})">X</button>
      </div>`;
    });
    document.getElementById("list").innerHTML=h;
  });
}

function del(i){
  fetch('/api/schedule/delete?id='+i).then(()=>load());
}

load();
